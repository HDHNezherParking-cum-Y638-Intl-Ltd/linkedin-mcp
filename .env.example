# linkedin-mcp-server configuration (all optional — copy to .env to override).
# NOTE: there are NO credentials here. Login is interactive in a real browser window;
# your LinkedIn password is never read, stored, or logged by this server.

# Where the persistent Chrome profile (your logged-in session) is stored. Gitignored.
# LINKEDIN_SESSION_DIR=./session

# Where the local scheduler database lives. Gitignored.
# LINKEDIN_DB_PATH=./data/schedule.sqlite

# Run non-login actions headless (true|false). Default false (headed is less detectable).
# Login is ALWAYS headed regardless of this.
# LINKEDIN_HEADLESS=false

# How long (seconds) linkedin_login waits for you to finish manual login/2FA.
# LINKEDIN_LOGIN_TIMEOUT_SEC=300

# Scheduler poll interval in milliseconds.
# LINKEDIN_POLL_MS=30000

# Human-like pacing between UI steps: "minMs,maxMs".
# LINKEDIN_PACING_MS=400,1200
