{
  "name": "linkedin-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local MCP server to manage a personal LinkedIn account and the Pages it admins, via browser automation (LinkedIn web, not the official API).",
  "license": "MIT",
  "bin": {
    "linkedin-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "tsx src/smoke.ts",
    "test": "node --import tsx --test \"test/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.61.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
