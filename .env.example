# linkedin-mcp-server configuration (all optional — copy to .env to override).
# NOTE: there are NO credentials here. Login is interactive in a real browser window;
# your LinkedIn password is never read, stored, or logged by this server.
#
# Loaded from two places, later wins:
#   1. <your home>/.linkedin-mcp/.env   <- use this when installed as a Claude Code plugin
#   2. ./.env                           <- repo-local, for development

# Root for session + scheduler state. Defaults to <your home>/.linkedin-mcp — outside the repo
# and outside the plugin cache, so a plugin update never wipes your login.
# NOTE: "~" is NOT expanded here — use an absolute path. And set this one as a real environment
# variable, not in a .env: the home directory is resolved before any .env is read.
# LINKEDIN_MCP_HOME=D:/linkedin-mcp-state

# Where the persistent Chrome profile (your logged-in session) is stored.
# Defaults to $LINKEDIN_MCP_HOME/session.
# LINKEDIN_SESSION_DIR=D:/linkedin-mcp-state/session

# Where the local scheduler database lives. Defaults to $LINKEDIN_MCP_HOME/schedule.sqlite.
# LINKEDIN_DB_PATH=D:/linkedin-mcp-state/schedule.sqlite

# Run non-login actions headless (true|false). Default false (headed is less detectable).
# Login is ALWAYS headed regardless of this.
# LINKEDIN_HEADLESS=false

# How long (seconds) linkedin_login waits for you to finish manual login/2FA.
# LINKEDIN_LOGIN_TIMEOUT_SEC=300

# Scheduler poll interval in milliseconds.
# LINKEDIN_POLL_MS=30000

# Human-like pacing between UI steps: "minMs,maxMs".
# LINKEDIN_PACING_MS=400,1200
